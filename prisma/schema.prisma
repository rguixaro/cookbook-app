generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Course {
  starter
  first_course
  second_course
  dessert
}

enum Category {
  pasta
  meat
  fish
  vegetable
  salad
  soup
  rice
  legume
  seafood
  fruit
  stew
  sauce
  marinade
  wok
}

enum ComplementType {
  sauce
  marinade
  garnish
}

enum Locale {
  ca
  en
  es
}

enum RecipeVisibility {
  private
  public
  showcase
}

type RecipeComplement {
  type         ComplementType
  name         String?
  ingredients  String[]
  instructions String
}

model Recipe {
  id            String              @id @default(auto()) @map("_id") @db.ObjectId
  slug          String
  defaultLocale Locale              @default(en)
  visibility    RecipeVisibility    @default(public)
  time          Int?
  images        String[]
  sourceUrls    String[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  course        Course
  categories    Category[]          @default([])
  author        User?               @relation(references: [id], fields: [authorId], onDelete: Cascade)
  authorId      String?             @db.ObjectId
  translations  RecipeTranslation[]

  @@unique([slug, authorId])
  @@index([authorId])
  @@index([visibility])
  @@index([course])
  @@index([categories])
}

model RecipeTranslation {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  recipeId     String             @db.ObjectId
  recipe       Recipe             @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  locale       Locale
  name         String
  ingredients  String[]
  instructions String
  complements  RecipeComplement[]

  @@unique([recipeId, locale])
  @@index([locale])
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String   @db.ObjectId

  @@index([userId])
}

model User {
  id                      String                   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  image                   String?
  name                    String?
  username                String                   @unique
  email                   String                   @unique
  passwordHash            String?
  passwordChangedAt       DateTime?
  sessionVersion          Int                      @default(0)
  emailVerified           DateTime?
  isPrivate               Boolean                  @default(true)
  savedRecipes            String[]
  favouriteRecipes        String[]
  accounts                Account[]
  sessions                Session[]
  recipes                 Recipe[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  emailChangeTokens       EmailChangeToken[]

  @@index([isPrivate])
}

model EmailVerificationToken {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailChangeToken {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  newEmail  String
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([newEmail])
  @@index([expiresAt])
}
